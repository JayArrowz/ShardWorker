@namespace ShardWorker.Dashboard.Components
@inject ShardDashboardService DashboardService

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ShardWorker Dashboard</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #f1f5f9; color: #1e293b; min-height: 100vh; }

        /* ── Header ── */
        .sw-header { background: #0f172a; color: #f8fafc; padding: 14px 24px; display: flex; align-items: center; justify-content: space-between; gap: 16px; }
        .sw-header-title { display: flex; align-items: center; gap: 10px; font-size: 1.1rem; font-weight: 600; letter-spacing: -0.01em; }
        .sw-header-title svg { opacity: 0.85; }
        .sw-header-meta { text-align: right; font-size: 0.75rem; color: #94a3b8; line-height: 1.6; }

        /* ── Refresh bar ── */
        .sw-refresh-bar { height: 3px; background: #3b82f6; animation: sw-shrink 5s linear forwards; }
        @@keyframes sw-shrink { from { width: 100%; } to { width: 0%; } }

        /* ── Layout ── */
        .sw-container { max-width: 1100px; margin: 24px auto; padding: 0 16px; display: grid; gap: 16px; }

        /* ── Card ── */
        .sw-card { background: #fff; border-radius: 10px; box-shadow: 0 1px 3px rgba(0,0,0,.08), 0 1px 2px rgba(0,0,0,.06); overflow: hidden; }
        .sw-card-header { padding: 14px 18px; border-bottom: 1px solid #e2e8f0; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 10px; }
        .sw-worker-name { font-weight: 700; font-size: 1rem; }
        .sw-no-query { font-size: 0.72rem; background: #fef9c3; color: #92400e; border: 1px solid #fde68a; padding: 3px 8px; border-radius: 4px; }

        /* ── Stats row ── */
        .sw-stats { display: flex; gap: 20px; flex-wrap: wrap; }
        .sw-stat { display: flex; flex-direction: column; align-items: center; min-width: 44px; }
        .sw-stat-value { font-size: 1.6rem; font-weight: 800; line-height: 1; }
        .sw-stat-label { font-size: 0.65rem; font-weight: 600; letter-spacing: 0.06em; color: #94a3b8; margin-top: 2px; }
        .sw-stat-total    .sw-stat-value { color: #334155; }
        .sw-stat-held     .sw-stat-value { color: #2563eb; }
        .sw-stat-free     .sw-stat-value { color: #94a3b8; }
        .sw-stat-inst     .sw-stat-value { color: #7c3aed; }
        .sw-stat-coverage .sw-stat-value { color: #64748b; }

        /* ── Coverage bar ── */
        .sw-coverage-track { height: 4px; background: #e2e8f0; }
        .sw-coverage-fill { height: 100%; background: #3b82f6; }

        /* ── Card body ── */
        .sw-card-body { padding: 16px 18px; display: grid; gap: 14px; }

        /* ── TTL colours ── */
        .sw-ttl-ok   { color: #10b981; }
        .sw-ttl-warn { color: #f59e0b; }
        .sw-ttl-crit { color: #ef4444; }
        .sw-ttl-none { color: #94a3b8; }

        /* ── Mode 0: Labeled grid (up to 250 shards) ── */
        .sw-shard-grid { display: flex; flex-wrap: wrap; gap: 3px; }
        .sw-shard { width: 34px; height: 26px; border-radius: 4px; display: flex; align-items: center; justify-content: center; font-size: 0.6rem; font-weight: 700; cursor: default; transition: filter .15s; }
        .sw-shard:hover { filter: brightness(0.88); }
        .sw-shard-free { background: #e2e8f0; color: #94a3b8; }
        .sw-shard-held { color: #fff; }
        .sw-shard-expiring { outline: 2px solid #f59e0b; outline-offset: 1px; }

        /* ── Mode 1: Mini dot grid (251 to 1000 shards) ── */
        .sw-dot-grid { display: flex; flex-wrap: wrap; gap: 2px; }
        .sw-mini-dot { width: 10px; height: 10px; border-radius: 2px; cursor: default; flex-shrink: 0; }
        .sw-mini-dot:hover { opacity: 0.7; }
        .sw-mini-dot-free { background: #e2e8f0; }
        .sw-mini-dot-expiring { outline: 2px solid #f59e0b; outline-offset: 1px; }

        /* ── Mode 2: Proportion bar (>1000 shards) ── */
        .sw-prop-bar { display: flex; width: 100%; height: 40px; border-radius: 6px; overflow: hidden; }
        .sw-prop-segment { display: flex; align-items: center; justify-content: center; padding: 0 6px; font-size: 0.68rem; font-weight: 700; color: rgba(255,255,255,0.92); overflow: hidden; white-space: nowrap; cursor: default; min-width: 0; transition: opacity .15s; }
        .sw-prop-segment:hover { opacity: 0.8; }
        .sw-prop-free { background: #e2e8f0; color: #94a3b8; flex-grow: 1; }

        /* ── Grid footnote ── */
        .sw-grid-note { font-size: 0.72rem; color: #64748b; margin-top: 2px; }

        /* ── Instance list ── */
        .sw-instances { display: flex; flex-direction: column; gap: 6px; }
        .sw-instance-row { display: flex; align-items: center; gap: 8px; font-size: 0.8rem; flex-wrap: wrap; }
        .sw-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
        .sw-instance-id { font-family: ui-monospace, 'Cascadia Code', monospace; color: #475569; }
        .sw-instance-meta { color: #94a3b8; font-size: 0.73rem; }
        .sw-instance-shards { color: #94a3b8; font-size: 0.73rem; }

        /* ── Empty state ── */
        .sw-empty { color: #94a3b8; text-align: center; padding: 32px 16px; font-size: 0.9rem; line-height: 1.6; }
        .sw-empty code { background: #f1f5f9; padding: 2px 6px; border-radius: 4px; font-size: 0.85em; }
    </style>
</head>
<body>

<header class="sw-header">
    <div class="sw-header-title">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/>
            <path d="M15.54 8.46a5 5 0 0 1 0 7.07M8.46 8.46a5 5 0 0 0 0 7.07"/>
        </svg>
        ShardWorker Dashboard
    </div>
    <div class="sw-header-meta">
        <div>@_snapshot.Timestamp.ToString("yyyy-MM-dd HH:mm:ss") UTC</div>
        <div>Auto-refreshing every 5 s</div>
    </div>
</header>

<div class="sw-refresh-bar"></div>

<main class="sw-container">
@{
    var now = DateTimeOffset.UtcNow;
}

@if (!_snapshot.Workers.Any())
{
    <div class="sw-card">
        <div class="sw-empty">
            No workers registered.<br />
            Call <code>AddShardEngine&lt;TWorker&gt;()</code> to register workers, then <code>AddShardWorkerDashboard()</code> to enable the dashboard.
        </div>
    </div>
}

@foreach (var worker in _snapshot.Workers)
{
    var instanceOrder = worker.HeldLocks
        .Select(l => l.InstanceId).Distinct().OrderBy(x => x).ToList();

    var avgTtl = worker.HeldLocks.Count == 0 ? (double?)null
        : Math.Max(0, worker.HeldLocks.Average(l => (l.ExpiresAt - now).TotalSeconds));

    var coveragePct = worker.TotalShards == 0 ? 0.0
        : (double)worker.HeldCount / worker.TotalShards * 100.0;

    var coveragePctStr = coveragePct.ToString("F1", System.Globalization.CultureInfo.InvariantCulture);
    var coveragePctDisplay = coveragePct.ToString("F0");

    // 0 = labeled cells (up to 250)  1 = mini dots (251-1000)  2 = proportion bar (>1000)
    var renderMode = worker.TotalShards <= 250 ? 0
                   : worker.TotalShards <= 1000 ? 1
                   : 2;

    <div class="sw-card">
        <div class="sw-card-header">
            <span class="sw-worker-name">@worker.WorkerName</span>

            @if (!worker.SupportsQuery)
            {
                <span class="sw-no-query">Provider does not implement IShardLockQueryProvider — lock data unavailable</span>
            }

            <div class="sw-stats">
                <div class="sw-stat sw-stat-total">
                    <span class="sw-stat-value">@worker.TotalShards</span>
                    <span class="sw-stat-label">TOTAL</span>
                </div>
                <div class="sw-stat sw-stat-held">
                    <span class="sw-stat-value">@worker.HeldCount</span>
                    <span class="sw-stat-label">HELD</span>
                </div>
                <div class="sw-stat sw-stat-free">
                    <span class="sw-stat-value">@worker.FreeCount</span>
                    <span class="sw-stat-label">FREE</span>
                </div>
                <div class="sw-stat sw-stat-inst">
                    <span class="sw-stat-value">@instanceOrder.Count</span>
                    <span class="sw-stat-label">INSTANCES</span>
                </div>
                <div class="sw-stat sw-stat-coverage">
                    <span class="sw-stat-value">@coveragePctDisplay%</span>
                    <span class="sw-stat-label">COVERAGE</span>
                </div>
                <div class="sw-stat">
                    <span class="sw-stat-value @TtlClass(avgTtl)">@TtlText(avgTtl)</span>
                    <span class="sw-stat-label">AVG TTL</span>
                </div>
            </div>
        </div>

        <div class="sw-coverage-track">
            <div class="sw-coverage-fill" style="width:@coveragePctStr%"></div>
        </div>

        <div class="sw-card-body">

            @if (renderMode == 0)
            {
                <div class="sw-shard-grid">
                    @for (int i = 0; i < worker.TotalShards; i++)
                    {
                        var sl = worker.GetLock(i);
                        if (sl is not null)
                        {
                            var color = InstanceColor(sl.InstanceId, instanceOrder);
                            var expiring = (sl.ExpiresAt - now).TotalSeconds < 30;
                            var ttlSec = (int)Math.Max(0, (sl.ExpiresAt - now).TotalSeconds);
                            var tip = "Shard " + i + "\nInstance: " + sl.InstanceId + "\nExpires: " + sl.ExpiresAt.ToString("HH:mm:ss") + " UTC\nTTL: " + ttlSec + "s";
                            <div class="sw-shard sw-shard-held @(expiring ? "sw-shard-expiring" : "")"
                                 style="background:@color" title="@tip">@i</div>
                        }
                        else
                        {
                            <div class="sw-shard sw-shard-free" title="Shard @i — unclaimed">@i</div>
                        }
                    }
                </div>
            }
            else if (renderMode == 1)
            {
                <div>
                    <div class="sw-dot-grid">
                        @for (int i = 0; i < worker.TotalShards; i++)
                        {
                            var sl = worker.GetLock(i);
                            if (sl is not null)
                            {
                                var color = InstanceColor(sl.InstanceId, instanceOrder);
                                var expiring = (sl.ExpiresAt - now).TotalSeconds < 30;
                                var ttlSec = (int)Math.Max(0, (sl.ExpiresAt - now).TotalSeconds);
                                var tip = "Shard " + i + "\nInstance: " + sl.InstanceId + "\nTTL: " + ttlSec + "s";
                                <div class="sw-mini-dot @(expiring ? "sw-mini-dot-expiring" : "")"
                                     style="background:@color" title="@tip"></div>
                            }
                            else
                            {
                                <div class="sw-mini-dot sw-mini-dot-free" title="Shard @i — unclaimed"></div>
                            }
                        }
                    </div>
                    <div class="sw-grid-note">Each square = 1 shard · @worker.TotalShards total</div>
                </div>
            }
            else
            {
                var segments = instanceOrder
                    .Select(id => (
                        Id: id,
                        Count: worker.HeldLocks.Count(l => l.InstanceId == id),
                        Color: InstanceColor(id, instanceOrder)))
                    .Where(s => s.Count > 0)
                    .ToList();

                <div>
                    <div class="sw-prop-bar">
                        @foreach (var seg in segments)
                        {
                            var pct = (double)seg.Count / worker.TotalShards * 100.0;
                            var pctStr = pct.ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
                            var pctLabel = pct.ToString("F1");
                            var tip = seg.Id + "\n" + seg.Count + " shards (" + pctLabel + "%)";
                            <div class="sw-prop-segment" style="width:@pctStr%;background:@seg.Color" title="@tip">
                                @if (pct >= 8) { <text>@seg.Count</text> }
                            </div>
                        }
                        @if (worker.FreeCount > 0)
                        {
                            var pct = (double)worker.FreeCount / worker.TotalShards * 100.0;
                            var pctStr = pct.ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
                            var pctLabel = pct.ToString("F1");
                            var tip = "Unclaimed\n" + worker.FreeCount + " shards (" + pctLabel + "%)";
                            <div class="sw-prop-segment sw-prop-free" style="width:@pctStr%" title="@tip">
                                @if (pct >= 8) { <text>free (@worker.FreeCount)</text> }
                            </div>
                        }
                    </div>
                    <div class="sw-grid-note" style="margin-top:4px">Distribution bar · @worker.TotalShards shards · each coloured segment = one instance</div>
                </div>
            }

            @if (instanceOrder.Any())
            {
                <div class="sw-instances">
                    @foreach (var instanceId in instanceOrder)
                    {
                        var color = InstanceColor(instanceId, instanceOrder);
                        var held = worker.HeldLocks
                            .Where(l => l.InstanceId == instanceId)
                            .OrderBy(l => l.ShardIndex)
                            .ToList();
                        var minTtl = held.Count == 0 ? (double?)null
                            : Math.Max(0, held.Min(l => (l.ExpiresAt - now).TotalSeconds));
                        var shardList = held.Count <= 30
                            ? string.Join(", ", held.Select(l => l.ShardIndex))
                            : string.Join(", ", held.Take(30).Select(l => l.ShardIndex)) + " … (+" + (held.Count - 30) + " more)";

                        <div class="sw-instance-row">
                            <div class="sw-dot" style="background:@color"></div>
                            <span class="sw-instance-id">@instanceId</span>
                            <span class="sw-instance-meta">@held.Count shard@(held.Count == 1 ? "" : "s")</span>
                            @if (renderMode < 2 && held.Count <= 30)
                            {
                                <span class="sw-instance-shards">[@shardList]</span>
                            }
                            @if (minTtl.HasValue)
                            {
                                <span class="@TtlClass(minTtl)" style="font-size:0.72rem">min TTL: @TtlText(minTtl)</span>
                            }
                        </div>
                    }
                </div>
            }

        </div>
    </div>
}
</main>

<script>setTimeout(() => location.reload(), 5000);</script>

</body>
</html>

@code {
    private DashboardSnapshot _snapshot = DashboardSnapshot.Empty;

    protected override async Task OnInitializedAsync()
        => _snapshot = await DashboardService.GetSnapshotAsync();

    private static readonly string[] _colors =
    [
        "#3b82f6", "#10b981", "#f59e0b", "#8b5cf6",
        "#ef4444", "#06b6d4", "#ec4899", "#84cc16",
        "#f97316", "#14b8a6", "#a855f7", "#64748b"
    ];

    private static string InstanceColor(string instanceId, IList<string> order)
    {
        var idx = order.IndexOf(instanceId);
        return idx >= 0 ? _colors[idx % _colors.Length] : "#94a3b8";
    }

    private static string TtlClass(double? seconds) =>
        seconds is null ? "sw-ttl-none"
        : seconds > 60  ? "sw-ttl-ok"
        : seconds > 20  ? "sw-ttl-warn"
        : "sw-ttl-crit";

    private static string TtlText(double? seconds) =>
        seconds is null ? "—"
        : seconds < 1   ? "<1s"
        : seconds < 60  ? $"{(int)seconds}s"
        : $"{(int)(seconds / 60)}m {(int)(seconds % 60)}s";
}
